<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="350.0" prefWidth="300.0" spacing="10.0" style="-fx-background-color: #F5EFE6; -fx-border-color: #3E2723; -fx-border-width: 1;" xmlns="http://javafx.com/javafx/16" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.HistoryPaneController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
    <children>
        
        <Label text="Recent Activity" textFill="#3E2723">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>
        
        <ListView fx:id="historyListView" VBox.vgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-border-color: #D7CCC8;" />
        
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <Label text="Undo last:" textFill="#3E2723">
                    <font>
                        <Font size="13.0" />
                    </font>
                </Label>
                
                <Spinner fx:id="undoSpinner" prefWidth="80.0" />
                
                <Button fx:id="undoButton" mnemonicParsing="false" onAction="#handleUndo" style="-fx-background-color: #3E2723; -fx-text-fill: #F5EFE6;" text="Undo">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Button>
            </children>
        </HBox>
        
    </children>
</VBox>
